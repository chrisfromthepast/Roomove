.node-item-type-control text { fill: rgb(0, 0, 0); }

.node-item-type-control:hover path { fill: rgb(255, 255, 255); }

.node-item-type-layer path { fill: rgb(51, 85, 136); }

.node-item-type-activation path { fill: rgb(112, 41, 33); }

